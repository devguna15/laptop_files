WITH filtered_data AS (
    SELECT
        UPPER(td.SELLER_COUNTRY) AS SELLER_COUNTRY_NORM,
        td.SHIPMENT_VALUE
    FROM
        tdb_exports AS td
    WHERE
        td.SHIPPING_DATE BETWEEN '2024-04-01' AND '2026-03-31'
        AND UPPER(td.BUYER_COMPANY) IS NOT NULL AND TRIM(td.BUYER_COMPANY) <> ''
        AND (
            UPPER(td.BUYER_COMPANY) LIKE '%LLC TDL TEXTILE CENTER%'
            OR JAROWINKLER_SIMILARITY(UPPER(td.BUYER_COMPANY), UPPER('LLC TDL TEXTILE CENTER')) > 80
        )
        AND (
            UPPER(td.PRODUCT_DESCRIPTION) LIKE '%COTTON%'
            OR JAROWINKLER_SIMILARITY(UPPER(td.PRODUCT_DESCRIPTION), UPPER('COTTON')) > 80
        )
)
SELECT
    fd.SELLER_COUNTRY_NORM AS SELLER_COUNTRY,
    COALESCE(SUM(fd.SHIPMENT_VALUE), 0) AS total_value_usd
FROM
    filtered_data AS fd
GROUP BY
    fd.SELLER_COUNTRY_NORM
ORDER BY
    total_value_usd DESC
LIMIT 1;
