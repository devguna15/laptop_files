def append_message(session: Dict[str, Any], role: str, raw: str, normalized: Optional[str] = None):
    session["messages"].append({
        "role": role,
        "raw": raw,
        "normalized": normalized if normalized is not None else raw,
        "ts": now_ms(),
    })
    if len(session["messages"]) > 40:
        session["messages"] = session["messages"][-40:]

def recent_chat_turns(session: Dict[str, Any], n: int = 8) -> List[Dict[str, str]]:
    turns = session["messages"][-n:]
    out = []
    for t in turns:
        out.append({"role": t["role"], "content": t.get("normalized") or t.get("raw") or ""})
    return out

def build_response(session_id: str, session: Dict[str, Any], messages: List[Dict[str, Any]], status_code: int = 200):
    # store assistant text in chat history
    for m in messages:
        if m["type"] in {"answer", "clarification", "confirm"}:
            append_message(session, "assistant", m.get("content", ""))

    payload = {"session_id": session_id, "state": session["state"], "messages": messages}
    if status_code == 200:
        return payload
    return JSONResponse(status_code=status_code, content=payload)

def flatten_last_followups(session: Dict[str, Any]) -> set:
    out = set()
    for s in session["followup_memory"]["last_followups_sets"]:
        for q in s:
            out.add(q.strip())
    return out

def store_followup_set(session: Dict[str, Any], followups: List[str]) -> None:
    mem = session["followup_memory"]["last_followups_sets"]
    mem.append(followups[:3])
    if len(mem) > 2:
        mem[:] = mem[-2:]

def validate_followups(session: Dict[str, Any], followups: List[str]) -> bool:
    if not isinstance(followups, list) or len(followups) != 3:
        return False
    banned = flatten_last_followups(session)
    return all((isinstance(q, str) and q.strip() and q.strip() not in banned) for q in followups)

def safe_fallback_followups(session: Dict[str, Any]) -> List[str]:
    p = session["structured_context"].get("product") or {}
    label = p.get("name") or p.get("hs_code") or "this product"
    candidates = [
        f"Who are the top buyers of {label} in the last 24 months?",
        f"Which countries are showing increasing demand for {label}?",
        f"Which markets have low competition for {label}?",
        f"Who are the high-margin buyers for {label}?",
        f"Which month does the demand for {label} usually peak?",
    ]
    banned = flatten_last_followups(session)
    out = []
    for q in candidates:
        if q not in banned:
            out.append(q)
        if len(out) == 3:
            break
    while len(out) < 3:
        out.append(candidates[len(out)])
    return out

# =========================================================
# GEMINI CALL
# =========================================================
def call_gemini(prompt: str, max_tokens: int = 4000, temperature: float = 0.0) -> str:
    if not GEMINI_API_KEY:
        raise RuntimeError("GEMINI_API_KEY is not set")

    payload = {
        "contents": [{"parts": [{"text": prompt}]}],
        "generationConfig": {"temperature": temperature, "maxOutputTokens": max_tokens, "topP": 0.95},
    }
    resp = requests.post(
        GEMINI_MODEL_URL,
        headers={"Content-Type": "application/json"},
        params={"key": GEMINI_API_KEY},
        data=json.dumps(payload),
        timeout=120,
    )
    data = resp.json()
    if "error" in data:
        raise RuntimeError(data["error"].get("message", "Gemini API error"))
    return data["candidates"][0]["content"]["parts"][0]["text"]

