@app.post("/chat")
def chat(req: ChatRequest):
    if req.session_id not in SESSIONS:
        return json_error("Invalid session_id")

    session = SESSIONS[req.session_id]
    raw_message = (req.message or "").strip()
    if not raw_message:
        return json_error("Empty message")

    normalized_message = normalize_user_message(raw_message)
    append_message(session, "user", raw_message, normalized_message)

    # Handle yes/no during confirmation state
    if session["state"] == STATE_AWAITING_CONFIRMATION:
        low = normalized_message.lower().strip()
        if low in {"yes","y","ok","okay","proceed","run"}:
            return _confirm_internal(req.session_id, "proceed")
        if low in {"no","n","cancel","stop"}:
            return _confirm_internal(req.session_id, "cancel")
        # otherwise allow normal routing
        session["state"] = STATE_IDLE
        session["structured_context"]["pending_query_text"] = None

    # SETUP: expect product/hs
    if session["state"] == STATE_SETUP:
        parsed = extract_product_or_hs(normalized_message)
        product_label = parsed["name"] or parsed["hs_code"] or "this product"
        session["structured_context"]["product"] = {"name": parsed["name"], "hs_code": parsed["hs_code"]}
        session["active_focus"]["current_product"] = parsed["name"]
        session["active_focus"]["current_hs_code"] = parsed["hs_code"]
        session["state"] = STATE_IDLE
        session["active_focus"]["last_answer_type"] = "setup_answer"

        # initial followups (always executable)
        followups = [
            f"Who are the top buyers of {product_label} in the last 24 months?",
            f"Which countries are showing increasing demand for {product_label}?",
            f"Which month does the demand for {product_label} usually peak?",
        ]
        store_followup_set(session, followups)

        return build_response(
            req.session_id,
            session,
            [
                msg_answer(f"Got it. I’ll focus on: {product_label}"),
                msg_followup(followups, title="Here are 3 questions you can run:"),
            ],
        )

    # FOLLOWUP CLICK: guaranteed executable -> straight to confirm (no routing)
    if req.source == "followup":
        final_query_text = normalized_message
        session["structured_context"]["pending_query_text"] = final_query_text
        session["state"] = STATE_AWAITING_CONFIRMATION
        return build_response(
            req.session_id,
            session,
            [msg_confirm("Confirm:", data={"resolved_query": final_query_text})],
        )

    # If awaiting clarification, treat this message as clarification response -> Trade Agent
    if session["state"] == STATE_AWAITING_CLARIFICATION:
        extra = {"clarification_response": True, "previous_question": session["structured_context"].get("pending_clarification")}
        trade_out = trade_agent_call(session, normalized_message, extra=extra)
        return _handle_trade_agent_output(req.session_id, session, trade_out)

    # MAIN ROUTER: TRADE vs OFFTOPIC
    try:
        route_out = main_router_call(session, normalized_message)
        route = (route_out.get("route") or "").upper()
    except Exception:
        route = "TRADE" if session["structured_context"].get("product") else "OFFTOPIC"

    if route == "OFFTOPIC":
        offtopic_out = offtopic_agent_call(session, normalized_message)
        text = offtopic_out.get("assistant_text") or "Okay."
        followups = offtopic_out.get("followups") or []

        # store offtopic summary tiny
        topic = offtopic_out.get("topic") or "general"
        summary = offtopic_out.get("summary") or text[:120]
        session["offtopic_summary"].append({"topic": topic, "summary": summary, "ts": now_ms()})
        if len(session["offtopic_summary"]) > 10:
            session["offtopic_summary"] = session["offtopic_summary"][-10:]

        session["state"] = STATE_READY_FOR_NEW_QUERY
        session["active_focus"]["last_answer_type"] = "general_answer"

        msgs = [msg_answer(text)]
        if isinstance(followups, list) and len(followups) == 3 and validate_followups(session, followups):
            store_followup_set(session, followups)
            msgs.append(msg_followup(followups, title="Suggested questions:"))
        elif session["structured_context"].get("product"):
            fb = safe_fallback_followups(session)
            store_followup_set(session, fb)
            msgs.append(msg_followup(fb, title="Suggested questions:"))

        return build_response(req.session_id, session, msgs)

    # TRADE ROUTE -> Trade Agent
    trade_out = trade_agent_call(session, normalized_message)
    return _handle_trade_agent_output(req.session_id, session, trade_out)

def _handle_trade_agent_output(session_id: str, session: Dict[str, Any], trade_out: Dict[str, Any]):
    action = (trade_out.get("action") or "").upper()
    assistant_text = trade_out.get("assistant_text") or ""
    clarification_question = trade_out.get("clarification_question")
    final_query_text = trade_out.get("final_query_text")
    followups = trade_out.get("followups") or []

    msgs: List[Dict[str, Any]] = []

    # followups validation
    use_followups: Optional[List[str]] = None
    if isinstance(followups, list) and len(followups) == 3 and validate_followups(session, followups):
        use_followups = followups
        store_followup_set(session, followups)

    if action == "ASK_CLARIFICATION":
        q = clarification_question or (followups[0] if followups else "Can you clarify what you want to analyze?")
        session["state"] = STATE_AWAITING_CLARIFICATION
        session["structured_context"]["pending_clarification"] = {"question": q, "asked_at": now_ms()}
        session["active_focus"]["last_answer_type"] = "guidance_answer"
        msgs.append(msg_clarification(q))
        if use_followups:
            msgs.append(msg_followup(use_followups, title="Suggested questions:"))
        return build_response(session_id, session, msgs)

    if action == "CONFIRM_QUERY":
        if not final_query_text:
            # fallback to clarification
            session["state"] = STATE_AWAITING_CLARIFICATION
            q = "Please rephrase as a concrete executable trade question."
            session["structured_context"]["pending_clarification"] = {"question": q, "asked_at": now_ms()}
            msgs.append(msg_clarification(q))
            if not use_followups and session["structured_context"].get("product"):
                fb = safe_fallback_followups(session)
                store_followup_set(session, fb)
                msgs.append(msg_followup(fb, title="Suggested questions:"))
            elif use_followups:
                msgs.append(msg_followup(use_followups, title="Suggested questions:"))
            return build_response(session_id, session, msgs)

        session["structured_context"]["pending_query_text"] = final_query_text
        session["state"] = STATE_AWAITING_CONFIRMATION
        session["active_focus"]["last_answer_type"] = "guidance_answer"
        msgs.append(msg_confirm("Confirm:", data={"resolved_query": final_query_text}))
        if use_followups:
            msgs.append(msg_followup(use_followups, title="Next best questions:"))
        return build_response(session_id, session, msgs)

    # ANSWER_DIRECT_TRADE
    session["state"] = STATE_READY_FOR_NEW_QUERY
    session["active_focus"]["last_answer_type"] = "guidance_answer"
    msgs.append(msg_answer(assistant_text or "Okay."))
    if use_followups:
        msgs.append(msg_followup(use_followups, title="Suggested questions:"))
    elif session["structured_context"].get("product"):
        fb = safe_fallback_followups(session)
        store_followup_set(session, fb)
        msgs.append(msg_followup(fb, title="Suggested questions:"))
    return build_response(session_id, session, msgs)

@app.post("/confirm")
def confirm(req: ConfirmRequest):
    return _confirm_internal(req.session_id, (req.decision or "").strip().lower())

def _confirm_internal(session_id: str, decision: str):
    if session_id not in SESSIONS:
        return json_error("Invalid session_id")
    session = SESSIONS[session_id]

    if session["state"] != STATE_AWAITING_CONFIRMATION:
        return json_error("No pending query to confirm")

    if decision not in {"proceed", "cancel"}:
        return json_error("decision must be proceed|cancel")

    if decision == "cancel":
        session["state"] = STATE_IDLE
        session["structured_context"]["pending_query_text"] = None
        session["structured_context"]["pending_clarification"] = None
        session["active_focus"]["last_answer_type"] = "general_answer"

        fb = safe_fallback_followups(session) if session["structured_context"].get("product") else []
        if fb:
            store_followup_set(session, fb)

        msgs = [msg_answer("Cancelled. Ask a new question anytime.")]
        if fb:
            msgs.append(msg_followup(fb, title="Suggested questions:"))
        return build_response(session_id, session, msgs)

    # PROCEED
    final_query_text = session["structured_context"].get("pending_query_text") or ""
    session["structured_context"]["pending_query_text"] = None
    session["structured_context"]["pending_clarification"] = None

    result = execute_prompt_pipeline(final_query_text)

    stage = result.get("stage")
    narrative = (result.get("narrative") or "").strip()
    sql = result.get("sql") or ""
    rows = result.get("rows") or []
    error = result.get("error")

    # trace for right panel
    trace = {
        "sql": sql,
        "rows_preview": rows[:25],
        "prompt_a_raw": result.get("prompt_a_raw", ""),
        "prompt_a_parts": result.get("prompt_a_parts", {}),
        "meta": {"stage": stage},
    }
    if error:
        trace["error"] = error

    session["last_trace"] = trace
    session["active_focus"]["last_run_failed"] = bool(error)
    session["active_focus"]["last_answer_type"] = "db_answer"

    # execution history
    qid = (session["execution_history"][-1]["query_id"] + 1) if session["execution_history"] else 1
    session["execution_history"].append({
        "query_id": qid,
        "resolved_query_text": final_query_text,
        "stage": stage,
        "row_count": len(rows),
        "created_at": now_ms(),
    })
    if len(session["execution_history"]) > 10:
        session["execution_history"] = session["execution_history"][-10:]

    session["active_focus"]["last_executed_query_id"] = qid
    session["active_focus"]["last_executed_query_text"] = final_query_text

    session["state"] = STATE_READY_FOR_NEW_QUERY

    # followups after answer (progressive) – use safe fallback for now
    fb = safe_fallback_followups(session) if session["structured_context"].get("product") else []
    if fb:
        store_followup_set(session, fb)

    chat_text = narrative if narrative else ("Execution completed." if not error else "Execution finished with an issue. See right panel.")
    msgs = [msg_answer(chat_text, data=trace)]
    if fb:
        msgs.append(msg_followup(fb, title="Follow-up questions:"))
    return build_response(session_id, session, msgs)

