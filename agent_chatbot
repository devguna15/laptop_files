def parse_prompt_a_output(text: str) -> Dict[str, str]:
    raw = text or ""
    interp = ""
    plan = ""
    sql = ""

    m = re.search(r"(?is)Interpretation Summary\s*(.*?)(?:SQL Implementation Plan)", raw)
    if m:
        interp = m.group(1).strip()

    m = re.search(r"(?is)SQL Implementation Plan\s*(.*?)(?:Generated SQL)", raw)
    if m:
        plan = m.group(1).strip()

    m = re.search(r"(?is)Generated SQL\s*:?\s*([\s\S]*)$", raw)
    if m:
        sql = strip_markdown_fences(m.group(1).strip())

    if not sql:
        m = re.search(r"(?is)\b(WITH\b[\s\S]*?;|\bSELECT\b[\s\S]*?;)", raw)
        sql = m.group(1).strip() if m else ""

    return {"interpretation_summary": interp, "sql_plan": plan, "sql": sql, "raw": raw}

def parse_prompt_b_output(text: str) -> str:
    raw = strip_markdown_fences(text or "")
    m = re.search(r"(?is)\b(WITH\b[\s\S]*?;|\bSELECT\b[\s\S]*?;)", raw)
    return m.group(1).strip() if m else raw.strip()

def get_snowflake_conn():
    return snowflake.connector.connect(
        user=SNOWFLAKE_USER,
        password=SNOWFLAKE_PASSWORD,
        account=SNOWFLAKE_ACCOUNT,
        warehouse=SNOWFLAKE_WAREHOUSE,
        database=SNOWFLAKE_DATABASE,
        schema=SNOWFLAKE_SCHEMA,
        role=SNOWFLAKE_ROLE if SNOWFLAKE_ROLE else None,
    )

def try_run_snowflake(sql: str) -> Tuple[bool, List[Dict[str, Any]], str]:
    conn = None
    cur = None
    try:
        conn = get_snowflake_conn()
        cur = conn.cursor()
        cur.execute(sql)
        cols = [d[0] for d in cur.description] if cur.description else []
        rows = cur.fetchall() if cur.description else []
        return True, [dict(zip(cols, r)) for r in rows], ""
    except Exception as e:
        return False, [], str(e)
    finally:
        if cur:
            cur.close()
        if conn:
            conn.close()

def is_infra_error(error_msg: str) -> bool:
    s = (error_msg or "").lower()
    infra_keywords = [
        "permission denied","could not connect","connection refused","timeout",
        "authentication failed","warehouse suspended","warehouse not found",
        "role not found","database not found","schema not found","account not found",
    ]
    return any(kw in s for kw in infra_keywords)

def format_attempt_history(attempts: List[Dict[str, str]]) -> str:
    lines = []
    for idx, att in enumerate(attempts, start=1):
        lines.append(f"Attempt {idx}:\nSQL:\n{att['sql']}\nERROR:\n{att['error']}\n")
    return "\n".join(lines).strip()

def execute_prompt_pipeline(final_query_text: str) -> Dict[str, Any]:
    # SAFE: never throw; always return prompt_a trace
    a_text = ""
    a_parts = {"interpretation_summary": "", "sql_plan": "", "sql": "", "raw": ""}

    try:
        prompt_a = build_prompt_a(final_query_text)
        a_text = call_gemini(prompt_a, max_tokens=22000, temperature=0.0)
        a_parts = parse_prompt_a_output(a_text)
        a_parts["raw"] = a_text

        sql_to_run = (a_parts.get("sql") or "").strip()
        if not sql_to_run:
            return {
                "stage": "prompt_a_no_sql",
                "narrative": "Prompt A did not produce SQL.",
                "sql": "",
                "rows": [],
                "cols": [],
                "prompt_a_raw": a_text,
                "prompt_a_parts": a_parts,
                "error": "Prompt A did not produce SQL",
            }

        attempts: List[Dict[str, str]] = []
        for attempt_idx in range(1, MAX_SQL_FIX_ATTEMPTS + 1):
            ok, rows, err = try_run_snowflake(sql_to_run)

            if ok:
                safe_rows = convert_decimals(rows)
                cols = list(safe_rows[0].keys()) if safe_rows else []

                prompt_c = build_prompt_c(
                    user_query=final_query_text,
                    interpretation=a_parts.get("interpretation_summary", ""),
                    plan=a_parts.get("sql_plan", ""),
                    executed_sql=sql_to_run,
                    rows=safe_rows,
                    cols=cols,
                )
                narrative = call_gemini(prompt_c, max_tokens=6000, temperature=0.0).strip()

                return {
                    "stage": "success",
                    "narrative": narrative,
                    "sql": sql_to_run,
                    "rows": safe_rows,
                    "cols": cols,
                    "prompt_a_raw": a_text,
                    "prompt_a_parts": a_parts,
                    "error": None,
                }

            attempts.append({"sql": sql_to_run, "error": err})

            if is_infra_error(err) or attempt_idx == MAX_SQL_FIX_ATTEMPTS:
                return {
                    "stage": "sql_execution_failure",
                    "narrative": "SQL execution failed after retries.",
                    "sql": sql_to_run,
                    "rows": [],
                    "cols": [],
                    "prompt_a_raw": a_text,
                    "prompt_a_parts": a_parts,
                    "error": err,
                }

            prompt_b = build_prompt_b(
                user_query=final_query_text,
                interpretation=a_parts.get("interpretation_summary", ""),
                plan=a_parts.get("sql_plan", ""),
                attempt_history=format_attempt_history(attempts[-3:]),
                latest_sql=sql_to_run,
                latest_error=err,
                latest_attempt_index=attempt_idx,
            )
            repaired_sql_raw = call_gemini(prompt_b, max_tokens=8000, temperature=0.0)
            sql_to_run = parse_prompt_b_output(repaired_sql_raw)

        return {
            "stage": "unknown_failure",
            "narrative": "Execution failed.",
            "sql": sql_to_run,
            "rows": [],
            "cols": [],
            "prompt_a_raw": a_text,
            "prompt_a_parts": a_parts,
            "error": "Unknown execution failure",
        }

    except Exception as e:
        return {
            "stage": "pipeline_exception",
            "narrative": "Pipeline exception occurred.",
            "sql": "",
            "rows": [],
            "cols": [],
            "prompt_a_raw": a_text,
            "prompt_a_parts": a_parts,
            "error": str(e),
        }

